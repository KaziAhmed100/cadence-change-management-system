# -----------------------------------------------------------------------------
# Cadence frontend — environment variables (example)
# -----------------------------------------------------------------------------
# Copy this file to `.env.local` and adjust for your environment.
# Anything prefixed NEXT_PUBLIC_ is exposed to the browser; everything else
# stays server-side.

# Base URL for the FastAPI backend
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# NextAuth — used from Phase 8 onward
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=replace-me-with-a-real-secret
