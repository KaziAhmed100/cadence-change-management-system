# -----------------------------------------------------------------------------
# Cadence — root .env (example)
# -----------------------------------------------------------------------------
# These values are picked up by docker-compose for the Postgres/Redis services.
# Copy to `.env` and adjust if you need different ports or credentials locally.
# The backend and frontend have their own .env files in their respective dirs.

# Postgres
POSTGRES_USER=cadence
POSTGRES_PASSWORD=cadence
POSTGRES_DB=cadence
POSTGRES_PORT=5432

# Redis
REDIS_PORT=6379
